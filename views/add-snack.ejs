<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>cleanier-snack</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD"
      crossorigin="anonymous"
    />
    <link href="../css/add-snack.css" rel="stylesheet" />
  </head>

  <body>
    <nav class="navbar navbar-expand-sm navbar" style="padding: 30px">
        <div class="container-fluid">
          <a href="/index-login"><img src="../namecard.png" /></a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#collapsibleNavbar"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div
            class="collapse navbar-collapse justify-content-end"
            id="collapsibleNavbar"
          ></div>
        </div>
      </nav>

      <div class="list-container">
        <div class="nav-container">
          <h1>
            <span><a href="/admin-user-list">고객관리</a></span> |
            <span><a href="/admin-snack-list">간식관리</a></span>
          </h1>
        </div>
            <form action="/add-snack" method="post">
              <h1>간식 등록</h1>
        
              <fieldset>
                <label for="name">간식 이름:</label>
                <input type="text" id="name" name="snack_name" style="background-color: #E8F0FE;"/>
        
                <label for="mail">간식 사진:</label>
                <input type="file" name="snack_img" accept="image/gif, image/jpeg, image/png" style="background-color: #E8F0FE;"/>
              </fieldset>
        
              <a><button type="submit" id="submit" style="background-color: #00d2b7; border: none;">간식 등록</button>
            </form>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
      crossorigin="anonymous"
    ></script>
    <script src="https://code.jquery.com/jquery-3.6.3.min.js"></script>
    </script>
  </body>
</html>
