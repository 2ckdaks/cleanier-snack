<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>cleanier-snack</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD"
      crossorigin="anonymous"
    />
    <link href="../css/request.css" rel="stylesheet" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css"
      integrity="sha512-SzlrxWUlpfuzQ+pcUCosxcglQRNAq/DZjVsC0lE40xsADsfeQoEypE+enwcOiGjk/bSuGGKHEyjSoQ1zVisanQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>

  <body class="body">
    <nav class="navbar navbar-expand-sm navbar" style="padding: 30px">
      <div class="container-fluid">
        <a href="/index-login"><img src="../namecard.png" /></a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#collapsibleNavbar"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div
          class="collapse navbar-collapse justify-content-end"
          id="collapsibleNavbar"
        >
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="#">서비스 소개</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">상품 소개</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="#">플랜 소개</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/request">간식 요청</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">로그아웃</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="main-container">
      <div class="user-snack">
        <h4><%= client.name %> 간식목록</h4>
        <hr />
        <div class="container" style="height: 600px; overflow-y: scroll">
          <div class="row">
            <div class="col-12">
              <ul class="list-group">
                <% for (let i = 0; i < user_snack.length; i++){ %>
                <li
                  class="list-group-item"
                  style="display: flex; justify-content: space-between"
                >
                  <div style="display: flex; justify-content: center">
                    <div style="width: 50px; height: 50px">
                      <img
                        style="width: 100%; height: 100%"
                        src="<%= user_snack[i].snack_src %>"
                      />
                    </div>
                    <p style="padding-top: 10px; margin-left: 10px">
                      <%= user_snack[i].snack_name %>
                    </p>
                  </div>
                </li>
                <% } %>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="user-container">
        <div class="user-req-free">
          <form action="/add-request" method="POST">
            <h4>요청사항</h4>
            <hr />
            <textarea
              name="request"
              style="height: 200px"
              minlength="1"
              required
              placeholder="요청사항을 입력해주세요"
            ></textarea>
            <button
              type="submit"
              class="btn btn-success"
              style="background-color: #00d2b7; border: none"
            >
              요청하기
            </button>
          </form>

          <br /><br /><br />

          <!-- <div class="container" style="height: 400px; overflow-y: scroll">
            <ul class="list-group">
              <% for (let i = request.length - 1; i >= 0; i--){ %>
              <li
                class="list-group-item"
                style="display: flex; justify-content: space-between"
              >
                <p><%= request[i].request %></p>
              </li>
              <% } %>
            </ul>
          </div> -->
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
      crossorigin="anonymous"
    ></script>
    <script src="https://code.jquery.com/jquery-3.6.3.min.js"></script>
    <script>
      $(".fa-solid").click(function (e) {
        $.ajax({
          method: "POST",
          url: "/update-good",
          data: { _id: e.target.dataset.id },
        })
          .done((결과) => {
            $(".body").html(결과);
          })
          .fail((에러) => {
            console.log(에러);
          });
      });
    </script>
  </body>
</html>
