<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>cleanier-snack</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD"
      crossorigin="anonymous"
    />
    <link href="../css/request.css" rel="stylesheet" />
  </head>

  <body>
    <%- include('user-nav.html') %>

    <div class="main-container">
      <div class="user-snack">
        <h4>한국공간데이터 간식 목록</h4>
        <hr />
        <div class="container" style="height: 600px; overflow-y: scroll">
          <div class="row">
            <div class="col-12">
              <ul class="list-group">
                <li class="list-group-item">
                  <img
                    src="../snack-img/마가렛트.jpg"
                    style="width: 50px; height: 50px"
                  />Lorem
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="user-container">
        <div class="user-req-free">
          <form action="/add-request" method="POST">
            <h4>요청사항</h4>
            <hr />
            <textarea
              name="request"
              style="height: 200px"
              minlength="1"
              required
              placeholder="요청사항을 입력해주세요"
            ></textarea>
            <button type="submit" class="btn btn-success">요청하기</button>
          </form>

          <br /><br /><br />

          <div class="container" style="height: 400px; overflow-y: scroll">
            <ul class="list-group">
              <% for (let i = test.length - 1; i >= 0; i--){ %>
              <li class="list-group-item">
                <p><%= test[i].request %></p>
                <!--관리자 기능에서 쓸만한 삭제버튼
                <button class="delete" data-id="<%=test[i]._id %>">삭제</button>
                -->
              </li>
              <% } %>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
      crossorigin="anonymous"
    ></script>
    <script src="https://code.jquery.com/jquery-3.6.3.min.js"></script>

    <!--관리자 기능에서 쓸만한 삭제기능
    <script>
      $(".delete").click(function (e) {
        $.ajax({
          method: "DELETE",
          url: "/delete-request",
          data: { _id: e.target.dataset.id },
        })
          .done((결과) => {
            $(this).parent("li").fadeOut();
          })
          .fail((에러) => {
            console.log(에러);
          });
      });
      -->
    </script>
  </body>
</html>
